generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  HEAD_NURSE
  STOREKEEPER
  NURSE
  MANAGER
}

enum LocationType {
  MAIN_STORAGE
  CABINET
}

model User {
  id                Int                  @id @default(autoincrement())
  email             String               @unique
  password          String
  role              Role                 @default(NURSE)
  name              String?
  isActive          Boolean              @default(true)
  pushToken         String?
  transactions      Transaction[]
  procedureLogs     ProcedureLog[]
  inventorySessions InventorySession[]
  auditLogs         AuditLog[]
  replenishmentRequests  ReplenishmentRequest[] @relation("ReplenishmentRequester")
  replenishmentResolved  ReplenishmentRequest[] @relation("ReplenishmentResolver")
  notifications          Notification[]
  notificationSettings   NotificationSettings?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model Location {
  id                Int                  @id @default(autoincrement())
  name              String
  type              LocationType         @default(CABINET)
  description       String?
  batches           Batch[]
  transactions      Transaction[]
  procedureLogs     ProcedureLog[]
  inventorySessions InventorySession[]   // <-- Added relation
  replenishmentRequests ReplenishmentRequest[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model Medication {
  id             Int                    @id @default(autoincrement())
  barcodes       String[]
  name           String
  mnn            String?
  form           String?
  unit           String?
  group          String?
  minQuantity    Int                    @default(10)
  batches        Batch[]
  transactions   Transaction[]
  procedureNorms ProcedureNorm[]
  inventoryItems InventoryItem[]        // <-- Added relation
  replenishmentRequests ReplenishmentRequest[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([name])
}

model Batch {
  id             Int        @id @default(autoincrement())
  medicationId   Int
  medication     Medication @relation(fields: [medicationId], references: [id])
  locationId     Int
  location       Location   @relation(fields: [locationId], references: [id])
  quantity       Int
  price          Float?
  supplier       String?
  batchNumber    String?
  serialNumber   String? // <-- Added serialNumber
  expirationDate DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([medicationId])
  @@index([locationId])
  @@index([locationId, medicationId])
  @@index([expirationDate])
}

enum TransactionType {
  INCOME
  OUTFLOW
  RETURN
  WRITE_OFF
}

model Transaction {
  id               Int             @id @default(autoincrement())
  type             TransactionType
  quantity         Int
  medicationId     Int
  medication       Medication      @relation(fields: [medicationId], references: [id])
  locationId       Int
  location         Location        @relation(fields: [locationId], references: [id])
  userId           Int?
  user             User?           @relation(fields: [userId], references: [id])
  reason           String?
  quantityBefore   Int             @default(0)
  quantityAfter    Int             @default(0)
  batchNumber      String?
  serialNumber     String?
  expirationDate   DateTime?
  price            Float?
  supplier         String?
  purpose          String?
  receiver         String?
  targetLocationId Int?
  createdAt        DateTime        @default(now())

  @@index([medicationId])
  @@index([locationId])
  @@index([locationId, createdAt])
  @@index([type])
  @@index([createdAt])
  @@index([reason])
}

model Procedure {
  id          Int             @id @default(autoincrement())
  name        String
  description String?
  standard    String?         // ГОСТ / СанПиН / Клинический протокол
  norms       ProcedureNorm[]
  logs        ProcedureLog[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ProcedureNorm {
  id               Int        @id @default(autoincrement())
  procedureId      Int
  procedure        Procedure  @relation(fields: [procedureId], references: [id])
  medicationId     Int
  medication       Medication @relation(fields: [medicationId], references: [id])
  expectedQuantity Float      @default(1.0)
  tolerancePercent Float      @default(0.0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model ProcedureLog {
  id          Int       @id @default(autoincrement())
  procedureId Int
  procedure   Procedure @relation(fields: [procedureId], references: [id])
  locationId  Int
  location    Location  @relation(fields: [locationId], references: [id])
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  quantity    Int       @default(1) // количество манипуляций за смену
  note        String?             // примечание смедсестры
  createdAt   DateTime  @default(now())

  @@index([createdAt])
  @@index([locationId, createdAt])
  @@index([userId])
  @@index([procedureId])
}

enum InventoryStatus {
  ACTIVE
  COMPLETED
}

model InventorySession {
  id          Int             @id @default(autoincrement())
  locationId  Int
  location    Location        @relation(fields: [locationId], references: [id])
  userId      Int
  user        User            @relation(fields: [userId], references: [id])
  status      InventoryStatus @default(ACTIVE)
  items       InventoryItem[]
  createdAt   DateTime        @default(now())
  completedAt DateTime?

  @@index([locationId])
  @@index([status])
}

model InventoryItem {
  id               Int              @id @default(autoincrement())
  sessionId        Int
  session          InventorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  medicationId     Int
  medication       Medication       @relation(fields: [medicationId], references: [id])
  expectedQuantity Int
  actualQuantity   Int? // null means not scanned yet
  difference       Int? // actualQuantity - expectedQuantity
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([sessionId])
  @@index([medicationId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  endpoint  String?
  ipAddress String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

enum ReplenishmentStatus {
  PENDING
  ACKNOWLEDGED
  FULFILLED
  REJECTED
}

// ТЗ 3.6: Запрос пополнения от медсестры кабинета
model ReplenishmentRequest {
  id           Int                  @id @default(autoincrement())
  medicationId Int
  medication   Medication           @relation(fields: [medicationId], references: [id])
  locationId   Int
  location     Location             @relation(fields: [locationId], references: [id])
  requestedBy  Int
  requester    User                 @relation("ReplenishmentRequester", fields: [requestedBy], references: [id])
  quantity     Int
  comment      String?
  status       ReplenishmentStatus  @default(PENDING)
  resolvedBy   Int?
  resolver     User?                @relation("ReplenishmentResolver", fields: [resolvedBy], references: [id])
  resolvedAt   DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@index([status])
  @@index([requestedBy])
  @@index([locationId])
  @@index([createdAt])
}

// ─── Ф-30: Система уведомлений ────────────────────────────────────────────────

enum NotificationType {
  CRITICAL_STOCK
  EXPIRING_SOON
  DEVIATION_EXCEEDED
  REPLENISHMENT_REQUESTED
}

// Настройки уведомлений (1 запись на пользователя)
model NotificationSettings {
  id                   Int      @id @default(autoincrement())
  userId               Int      @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  criticalStockEnabled Boolean  @default(true)
  deviationEnabled     Boolean  @default(true)
  expiringEnabled      Boolean  @default(true)
  deviationThreshold   Int      @default(20)   // % перерасхода — порог срабатывания
  emailEnabled         Boolean  @default(false)
  inAppEnabled         Boolean  @default(true)
  notifyEmail          String?  // отдельный email для уведомлений (если отличается от login)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// In-app уведомления
model Notification {
  id        Int                @id @default(autoincrement())
  userId    Int
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  isRead    Boolean            @default(false)
  meta      Json?              // { medicationId?, locationId?, deviationPct? }
  createdAt DateTime           @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([createdAt])
}
