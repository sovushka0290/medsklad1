generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  HEAD_NURSE
  STOREKEEPER
  NURSE
  MANAGER
}

enum LocationType {
  MAIN_STORAGE
  CABINET
}

model User {
  id                Int                @id @default(autoincrement())
  email             String             @unique
  password          String
  role              Role               @default(NURSE)
  name              String?
  isActive          Boolean            @default(true) // <-- Added isActive
  pushToken         String? // <-- Added pushToken
  transactions      Transaction[]
  procedureLogs     ProcedureLog[]
  inventorySessions InventorySession[] // <-- Added relation
  auditLogs         AuditLog[]         // <-- Added relation
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Location {
  id                Int                @id @default(autoincrement())
  name              String
  type              LocationType       @default(CABINET)
  description       String?
  batches           Batch[]
  transactions      Transaction[]
  procedureLogs     ProcedureLog[]
  inventorySessions InventorySession[] // <-- Added relation
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

model Medication {
  id             Int             @id @default(autoincrement())
  barcodes       String[]
  name           String
  mnn            String?
  form           String?
  unit           String?
  group          String?
  minQuantity    Int             @default(10)
  batches        Batch[]
  transactions   Transaction[]
  procedureNorms ProcedureNorm[]
  inventoryItems InventoryItem[] // <-- Added relation
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([name])
}

model Batch {
  id             Int        @id @default(autoincrement())
  medicationId   Int
  medication     Medication @relation(fields: [medicationId], references: [id])
  locationId     Int
  location       Location   @relation(fields: [locationId], references: [id])
  quantity       Int
  price          Float?
  supplier       String?
  serialNumber   String? // <-- Added serialNumber
  expirationDate DateTime?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([medicationId])
  @@index([locationId])
  @@index([locationId, medicationId])
}

enum TransactionType {
  INCOME
  OUTFLOW
  RETURN
  WRITE_OFF
}

model Transaction {
  id             Int             @id @default(autoincrement())
  type           TransactionType
  quantity       Int
  medicationId   Int
  medication     Medication      @relation(fields: [medicationId], references: [id])
  locationId     Int
  location       Location        @relation(fields: [locationId], references: [id])
  userId         Int?
  user           User?           @relation(fields: [userId], references: [id])
  reason         String?
  quantityBefore Int             @default(0)
  quantityAfter  Int             @default(0)
  createdAt      DateTime        @default(now())

  @@index([medicationId])
  @@index([locationId])
  @@index([locationId, createdAt])
  @@index([type])
  @@index([createdAt])
}

model Procedure {
  id          Int             @id @default(autoincrement())
  name        String
  description String?
  norms       ProcedureNorm[]
  logs        ProcedureLog[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ProcedureNorm {
  id               Int        @id @default(autoincrement())
  procedureId      Int
  procedure        Procedure  @relation(fields: [procedureId], references: [id])
  medicationId     Int
  medication       Medication @relation(fields: [medicationId], references: [id])
  expectedQuantity Float      @default(1.0)
  tolerancePercent Float      @default(0.0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model ProcedureLog {
  id          Int       @id @default(autoincrement())
  procedureId Int
  procedure   Procedure @relation(fields: [procedureId], references: [id])
  locationId  Int
  location    Location  @relation(fields: [locationId], references: [id])
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())

  @@index([createdAt])
  @@index([locationId, createdAt])
}

enum InventoryStatus {
  ACTIVE
  COMPLETED
}

model InventorySession {
  id          Int             @id @default(autoincrement())
  locationId  Int
  location    Location        @relation(fields: [locationId], references: [id])
  userId      Int
  user        User            @relation(fields: [userId], references: [id])
  status      InventoryStatus @default(ACTIVE)
  items       InventoryItem[]
  createdAt   DateTime        @default(now())
  completedAt DateTime?

  @@index([locationId])
  @@index([status])
}

model InventoryItem {
  id               Int              @id @default(autoincrement())
  sessionId        Int
  session          InventorySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  medicationId     Int
  medication       Medication       @relation(fields: [medicationId], references: [id])
  expectedQuantity Int
  actualQuantity   Int? // null means not scanned yet
  difference       Int? // actualQuantity - expectedQuantity
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([sessionId])
  @@index([medicationId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  endpoint  String?
  ipAddress String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}
