generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  HEAD_NURSE
  STOREKEEPER
  NURSE
}

enum LocationType {
  MAIN_STORAGE
  CABINET
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  password      String
  role          Role           @default(NURSE)
  name          String?
  transactions  Transaction[]
  procedureLogs ProcedureLog[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Location {
  id            Int            @id @default(autoincrement())
  name          String
  type          LocationType   @default(CABINET)
  description   String?
  batches       Batch[]
  transactions  Transaction[]
  procedureLogs ProcedureLog[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Medication {
  id             Int             @id @default(autoincrement())
  barcode        String          @unique
  name           String
  mnn            String?
  group          String?
  minQuantity    Int             @default(10)
  batches        Batch[]
  transactions   Transaction[]
  procedureNorms ProcedureNorm[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([name])
}

model Batch {
  id             Int        @id @default(autoincrement())
  quantity       Int        @default(0)
  medicationId   Int
  medication     Medication @relation(fields: [medicationId], references: [id])
  locationId     Int
  location       Location   @relation(fields: [locationId], references: [id])
  expirationDate DateTime?
  serialNumber   String?
  price          Float?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([medicationId])
  @@index([locationId])
}

enum TransactionType {
  INCOME
  OUTFLOW
}

model Transaction {
  id           Int             @id @default(autoincrement())
  type         TransactionType
  quantity     Int
  medicationId Int
  medication   Medication      @relation(fields: [medicationId], references: [id])
  locationId   Int
  location     Location        @relation(fields: [locationId], references: [id])
  userId       Int?
  user         User?           @relation(fields: [userId], references: [id])
  reason       String?
  createdAt    DateTime        @default(now())

  @@index([medicationId])
  @@index([locationId])
  @@index([type])
  @@index([createdAt])
}

model Procedure {
  id          Int             @id @default(autoincrement())
  name        String
  description String?
  norms       ProcedureNorm[]
  logs        ProcedureLog[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ProcedureNorm {
  id               Int        @id @default(autoincrement())
  procedureId      Int
  procedure        Procedure  @relation(fields: [procedureId], references: [id])
  medicationId     Int
  medication       Medication @relation(fields: [medicationId], references: [id])
  expectedQuantity Float      @default(1.0)
  tolerancePercent Float      @default(0.0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
}

model ProcedureLog {
  id           Int        @id @default(autoincrement())
  procedureId  Int
  procedure    Procedure  @relation(fields: [procedureId], references: [id])
  locationId   Int
  location     Location   @relation(fields: [locationId], references: [id])
  userId       Int
  user         User       @relation(fields: [userId], references: [id])
  createdAt    DateTime   @default(now())
}
