# ==========================================
# MedSklad Backend — Environment Variables
# ==========================================
# ВАЖНО: Скопируйте этот файл в .env и заполните реальными значениями
# НИКОГДА не коммитьте файл .env в репозиторий!
#
# Генерация секретов:
#   JWT_SECRET:              openssl rand -hex 64
#   REFRESH_TOKEN_SECRET:    openssl rand -hex 64
#   POSTGRES_PASSWORD:       openssl rand -hex 32

# --- Database ---
DATABASE_URL=postgresql://medsklad:CHANGE_ME_DB_PASS@localhost:5432/medsklad_db?schema=public
DIRECT_URL=postgresql://medsklad:CHANGE_ME_DB_PASS@localhost:5432/medsklad_db?schema=public
POSTGRES_PASSWORD=CHANGE_ME_DB_PASS

# --- Authentication (ОБЯЗАТЕЛЬНО — мин. 32 символа) ---
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS_LONG_JWT_SECRET_HERE
REFRESH_TOKEN_SECRET=CHANGE_ME_SEPARATE_REFRESH_SECRET_HERE

# --- Server ---
PORT=3000
NODE_ENV=development

# --- CORS (через запятую без пробелов) ---
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# --- External Services ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Optional: API Key для интеграций ---
# API_KEY=optional_internal_api_key

# --- Optional: Email Alerts ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=alerts@medsklad.kz
# SMTP_PASS=your_smtp_password
# SMTP_FROM=alerts@medsklad.kz
# ALERT_EMAIL=admin@medsklad.kz
